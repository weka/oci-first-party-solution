# Copy to terraform.tfvars and fill in. This ONE stack does cluster + WEKA.

# REQUIRED — your OCI account specifics:
# NOTE: OCI Resource Manager auto-populates tenancy_ocid and compartment_ocid; only set them for local/CLI runs.
tenancy_ocid     = "ocid1.tenancy.oc1..xxxxx"
compartment_ocid = "ocid1.compartment.oc1..xxxxx"

# REQUIRED — quay.io robot creds from https://get.weka.io (sensitive):
quay_username = "weka.io+robot"
quay_password = "..."

# SSH key: content (ORM) or path (local). Content wins when set.
# ssh_public_key      = "ssh-ed25519 AAAA... you@host"
# ssh_public_key_path = "~/.ssh/id_rsa.pub"

# Auth for the `oci` CLI calls (subnet attach + OKE token). Pick per environment:
#   - ORM runner / Cloud Shell: leave both unset (default oci_cli_auth = "" => no
#     --auth flag; the environment's delegation/session token is used).
#   - Local:                    config_file_profile = "DEFAULT"
#   - operator host:            oci_cli_auth = "instance_principal"
# config_file_profile = "DEFAULT"
# region              = "us-phoenix-1"

# --- Workers: converged WEKA nodes (optional) ---
# flavor           = "production"      # production:     DenseIO.E5.Flex + local NVMe (best perf, scarce quota) (default)
#                                      # non-production: Standard.E5.Flex + block volume
#
# production flavor — sized by target usable capacity (worker count is derived):
# target_usable_tb = 18                # ~18 TB ≈ 6-node min (3+2+1); ~43 TB ≈ 10 nodes (7+2+1); ~98 TB ≈ 19-21 nodes
#
# non-production flavor — you set the instance count + per-node block volume:
# node_count       = 6                 # minimum 6
# data_volume_gb   = 100               # block-volume size (GB); ignored for production

# --- Advanced overrides (optional; null = use flavor default; not shown in the ORM form) ---
# node_ocpus     = 16                   # override flavor default (e.g. 16 OCPU DenseIO = 2 NVMe)
# node_memory_gb = 192                  # override flavor default (OCI allows 1-48 GB/OCPU for DenseIO.E5.Flex)
# node_shape     = "VM.DenseIO.E5.Flex" # override flavor default shape

# --- Optional cluster/operator overrides (defaults shown) ---
# cluster_name     = "weka-cluster"
# operator_version = "v1.14.1"
