# Copy to terraform.tfvars and fill in your values.
#
# REQUIRED — no defaults (your OCI account specifics):
tenancy_id     = "ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
compartment_id = "ocid1.compartment.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Auth / region (optional; shown with defaults) ---
# Pick auth per environment for the one `oci` CLI call (subnet attach):
#   - ORM runner / Cloud Shell: leave both unset (default oci_cli_auth = "" => no --auth
#                               flag; the environment's delegation/session token is used)
#   - Local:                    config_file_profile = "DEFAULT"   # profile in ~/.oci/config
#   - operator host:            oci_cli_auth = "instance_principal"
# config_file_profile = "DEFAULT"
# region              = "us-phoenix-1"

# --- SSH key: content (ORM) or file path (local) ---
# ssh_public_key      = "ssh-ed25519 AAAA... you@host"   # paste content in the ORM runner
# ssh_public_key_path = "~/.ssh/id_rsa.pub"              # used only when ssh_public_key is null

# --- Cluster (optional) ---
# cluster_name       = "weka-oke"
# kubernetes_version = "v1.34.2"

# --- Workers: converged WEKA nodes (optional) ---
# flavor          = "non-production"   # non-production: Standard.E5.Flex + block volume (default)
#                                      # production:     DenseIO.E5.Flex + local NVMe (best perf, scarce quota)
# data_volume_gb  = 100                # block-volume size (GB) for non-production flavor; ignored for production
# node_count          = 6
# node_boot_volume_gb = 200

# --- Advanced sizing overrides (optional; null = use flavor default) ---
# node_ocpus     = 16                   # optional: override flavor default (e.g. 16 OCPU DenseIO = 2 NVMe)
# node_memory_gb = 192                  # optional: override flavor default (DenseIO E5 min 12 GB/OCPU)
# node_shape     = "VM.DenseIO.E5.Flex" # optional: override flavor default shape

# --- Control plane access (optional) ---
# control_plane_allowed_cidrs = ["0.0.0.0/0"]  # tighten to "<your-ip>/32" for anything real

# ---------------------------------------------------------------------------
# Reuse an EXISTING VCN instead of creating a fresh one.
# Uncomment and fill in with your own network OCIDs. A single flat subnet can be
# reused for cp/workers/pub_lb.
# ---------------------------------------------------------------------------
# create_vcn = false
# vcn_id     = "ocid1.vcn.oc1..xxxxx"
# subnets = {
#   cp      = { id = "ocid1.subnet.oc1..xxxxx" }
#   workers = { id = "ocid1.subnet.oc1..xxxxx" }
#   pub_lb  = { id = "ocid1.subnet.oc1..xxxxx" }
# }
# nsgs = {
#   cp      = { id = "ocid1.networksecuritygroup.oc1..xxxxx" }
#   workers = { id = "ocid1.networksecuritygroup.oc1..xxxxx" }
# }
